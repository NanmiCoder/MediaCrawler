# Docker Environment Configuration
# Copy this file to .env.docker and customize as needed

# Python Environment
PYTHONUNBUFFERED=1

# FastAPI Backend
API_HOST=0.0.0.0
API_PORT=8080

# Frontend React
REACT_APP_API_URL=http://backend:8080

# Database Configuration (Optional)
# DATABASE_URL=postgresql://user:password@postgres:5432/mediacrawler
# REDIS_URL=redis://redis:6379

# Logging
LOG_LEVEL=INFO

# Platform Settings
PLATFORM=xhs

# Save Format (json, jsonl, excel, db)
SAVE_DATA_OPTION=json
